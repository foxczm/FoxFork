;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="GDCShoot"
run/main_scene="uid://d3a6djfre3wqt"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="uid://tw5h2tr05v4x"

[autoload]

Director="*res://Misc/director.gd"
ServerDatabase="*uid://vp0x81lmogrn"
ClientUI="*uid://wv5shiqbwe6w"

[display]

